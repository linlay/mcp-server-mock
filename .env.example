# Preferred local port for `make run` and Docker Compose published port on host
HOST_PORT=11969

# Optional external structured config path; leave empty for the default embedded config
CONFIG_PATH=

# App runtime overrides
SERVER_PORT=8080
MCP_TOOLS_SPEC_LOCATION_PATTERN=./tools/*.yml
MCP_HTTP_MAX_BODY_BYTES=1048576
MCP_OBSERVABILITY_LOG_ENABLED=true
MCP_OBSERVABILITY_LOG_MAX_BODY_LENGTH=2000
MCP_OBSERVABILITY_LOG_INCLUDE_HEADERS=false
